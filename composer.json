{
    "name": "tawin/laravel-dev-tools",
    "description": "Laravel artisan commands for security and maintenance: list policies, model relations, and check routes missing authorization.",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0",
        "illuminate/console": "^10.0",
        "illuminate/routing": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Tawin\\LaravelDevTools\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tawin\\LaravelDevTools\\LaravelDevToolsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
